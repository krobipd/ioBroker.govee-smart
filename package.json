{
  "name": "iobroker.govee-smart",
  "version": "2.0.2",
  "description": "Control Govee WiFi devices via LAN, MQTT and Cloud.",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.govee-smart",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "govee",
    "smart home",
    "led",
    "light"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.govee-smart"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.1",
    "@types/node": "^25.5.2",
    "@types/node-forge": "^1.3.14",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3"
  },
  "main": "build/main.js",
  "files": [
    "admin",
    "build",
    "devices.json",
    "devices.schema.json",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "prebuild:test": "rimraf build-test",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "npm run build:test && mocha --exit \"build-test/test/test*.js\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run build && npm run test:ts && npm run test:package",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "translate": "translate-adapter",
    "release": "release-script",
    "validate-devices": "tsc tools/validate-devices.ts --module commonjs --target es2020 --outDir build-test/tools --esModuleInterop --skipLibCheck && node build-test/tools/validate-devices.js",
    "gen-wiki": "tsc tools/gen-wiki-devices.ts --module commonjs --target es2020 --outDir build-test/tools --esModuleInterop --skipLibCheck && node build-test/tools/gen-wiki-devices.js"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.govee-smart/issues"
  }
}
