{
  "name": "iobroker.govee-smart",
  "version": "1.1.2",
  "description": "Control Govee smart home devices via LAN, MQTT and Cloud",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "homepage": "https://github.com/krobipd/ioBroker.govee-smart",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "govee",
    "smart home",
    "led",
    "light"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.govee-smart"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/types": "^7.1.1",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^25.5.2",
    "@types/node-forge": "^1.3.14",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:package": "npm run build:test && mocha --exit \"build/test/testPackageFiles.js\"",
    "test:integration": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "test": "npm run build && npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.govee-smart/issues"
  }
}
