{
    "i18n": true,
    "type": "tabs",
    "items": {
        "_main": {
            "type": "panel",
            "label": "tabMain",
            "items": {
                "_lanHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "lanHeader",
                    "size": 4
                },
                "_lanInfo": {
                    "type": "staticText",
                    "text": "lanInfo",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 14, "marginBottom": 16 }
                },
                "networkInterface": {
                    "type": "ip",
                    "label": "networkInterfaceLabel",
                    "tooltip": "networkInterfaceTooltip",
                    "onlyIp4": true,
                    "noInternal": true,
                    "listenOnAllPorts": true,
                    "xs": 12, "sm": 12, "md": 6, "lg": 6, "xl": 6
                },

                "_cloudHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "cloudHeader",
                    "size": 5
                },
                "_cloudInfo": {
                    "type": "staticText",
                    "text": "cloudInfo",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 14, "marginBottom": 8 }
                },
                "apiKey": {
                    "type": "password",
                    "label": "apiKeyLabel",
                    "xs": 12, "sm": 12, "md": 8, "lg": 6, "xl": 6
                },

                "_mqttHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "mqttHeader",
                    "size": 5
                },
                "_mqttInfo": {
                    "type": "staticText",
                    "text": "mqttInfo",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 14, "marginBottom": 8 }
                },
                "goveeEmail": {
                    "type": "text",
                    "label": "emailLabel",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "goveePassword": {
                    "type": "password",
                    "label": "passwordLabel",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },

                "_supportHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "supportHeader",
                    "size": 5
                },
                "_aboutInfo": {
                    "type": "staticText",
                    "text": "aboutInfo",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 14, "marginBottom": 16 }
                },
                "_kofiLink": {
                    "type": "staticLink",
                    "href": "https://ko-fi.com/krobipd",
                    "label": "donateKofi",
                    "button": true,
                    "variant": "outlined",
                    "color": "primary",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                },
                "_paypalLink": {
                    "type": "staticLink",
                    "href": "https://paypal.me/krobipd",
                    "label": "donatePaypal",
                    "button": true,
                    "variant": "outlined",
                    "color": "primary",
                    "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
                }
            }
        },
        "_wizard": {
            "type": "panel",
            "label": "tabWizard",
            "items": {
                "_wizHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "wizardHeader",
                    "size": 4
                },
                "_wizInfo": {
                    "type": "staticText",
                    "text": "wizardInfo",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 14, "marginBottom": 16 }
                },
                "_wizDevice": {
                    "type": "selectSendTo",
                    "command": "getSegmentDevices",
                    "label": "wizardDeviceLabel",
                    "alsoDependsOn": [],
                    "noTranslation": true,
                    "xs": 12, "sm": 12, "md": 8, "lg": 6, "xl": 6
                },
                "_wizStart": {
                    "type": "sendTo",
                    "newLine": true,
                    "command": "segmentWizard",
                    "jsonData": "{ \"action\": \"start\", \"device\": \"${data._wizDevice}\" }",
                    "label": "wizardBtnStart",
                    "variant": "contained",
                    "color": "primary",
                    "xs": 12, "sm": 6, "md": 3, "lg": 2, "xl": 2
                },
                "_wizAbort": {
                    "type": "sendTo",
                    "command": "segmentWizard",
                    "jsonData": "{ \"action\": \"abort\" }",
                    "label": "wizardBtnAbort",
                    "variant": "outlined",
                    "color": "secondary",
                    "xs": 12, "sm": 6, "md": 3, "lg": 2, "xl": 2
                },
                "_wizStatus": {
                    "newLine": true,
                    "type": "state",
                    "oid": "info.wizardStatus",
                    "label": "wizardStatusLabel",
                    "foreign": false,
                    "controlDelay": 0,
                    "controls": "text",
                    "readOnly": true,
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 15, "fontWeight": "500", "marginTop": 16, "marginBottom": 8, "padding": 16, "backgroundColor": "rgba(33, 150, 243, 0.12)", "borderRadius": 4, "whiteSpace": "pre-line", "lineHeight": 1.5 }
                },
                "_wizYes": {
                    "newLine": true,
                    "type": "sendTo",
                    "command": "segmentWizard",
                    "jsonData": "{ \"action\": \"yes\" }",
                    "label": "wizardBtnYes",
                    "variant": "contained",
                    "color": "primary",
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "_wizNo": {
                    "type": "sendTo",
                    "command": "segmentWizard",
                    "jsonData": "{ \"action\": \"no\" }",
                    "label": "wizardBtnNo",
                    "variant": "outlined",
                    "color": "secondary",
                    "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
                },
                "_wizHelp": {
                    "newLine": true,
                    "type": "staticText",
                    "text": "wizardHelp",
                    "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
                    "style": { "fontSize": 13, "marginTop": 24, "opacity": 0.8 }
                }
            }
        }
    }
}
