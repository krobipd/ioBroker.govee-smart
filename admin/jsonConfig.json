{
    "i18n": true,
    "type": "panel",
    "items": {
        "_lanHeader": {
            "newLine": true,
            "type": "header",
            "text": "lanHeader",
            "size": 4
        },
        "_lanInfo": {
            "type": "staticText",
            "text": "lanInfo",
            "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
            "style": { "fontSize": 14, "marginBottom": 16 }
        },
        "networkInterface": {
            "type": "ip",
            "label": "networkInterfaceLabel",
            "tooltip": "networkInterfaceTooltip",
            "onlyIp4": true,
            "noInternal": true,
            "listenOnAllPorts": true,
            "xs": 12, "sm": 12, "md": 6, "lg": 6, "xl": 6
        },

        "_cloudHeader": {
            "newLine": true,
            "type": "header",
            "text": "cloudHeader",
            "size": 5
        },
        "_cloudInfo": {
            "type": "staticText",
            "text": "cloudInfo",
            "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
            "style": { "fontSize": 14, "marginBottom": 8 }
        },
        "apiKey": {
            "type": "password",
            "label": "apiKeyLabel",
            "xs": 12, "sm": 12, "md": 8, "lg": 6, "xl": 6
        },

        "_mqttHeader": {
            "newLine": true,
            "type": "header",
            "text": "mqttHeader",
            "size": 5
        },
        "_mqttInfo": {
            "type": "staticText",
            "text": "mqttInfo",
            "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
            "style": { "fontSize": 14, "marginBottom": 8 }
        },
        "goveeEmail": {
            "type": "text",
            "label": "emailLabel",
            "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
        },
        "goveePassword": {
            "type": "password",
            "label": "passwordLabel",
            "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
        },

        "_settingsHeader": {
            "newLine": true,
            "type": "header",
            "text": "settingsHeader",
            "size": 5
        },
        "pollInterval": {
            "type": "number",
            "label": "pollIntervalLabel",
            "min": 30,
            "max": 3600,
            "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
        },

        "_supportHeader": {
            "newLine": true,
            "type": "header",
            "text": "supportHeader",
            "size": 5
        },
        "_aboutInfo": {
            "type": "staticText",
            "text": "aboutInfo",
            "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12,
            "style": { "fontSize": 14, "marginBottom": 16 }
        },
        "_kofiLink": {
            "type": "staticLink",
            "href": "https://ko-fi.com/krobipd",
            "label": "donateKofi",
            "button": true,
            "variant": "outlined",
            "color": "primary",
            "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
        },
        "_paypalLink": {
            "type": "staticLink",
            "href": "https://paypal.me/krobipd",
            "label": "donatePaypal",
            "button": true,
            "variant": "outlined",
            "color": "primary",
            "xs": 12, "sm": 6, "md": 4, "lg": 4, "xl": 4
        }
    }
}
